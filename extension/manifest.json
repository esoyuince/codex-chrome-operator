{
  "manifest_version": 3,
  "name": "Codex Chrome Operator",
  "version": "0.2.9",
  "description": "Codex-controlled Chrome operator bridge with guarded local automation.",
  "permissions": [
    "nativeMessaging",
    "scripting",
    "activeTab",
    "tabs",
    "storage",
    "sidePanel",
    "debugger",
    "offscreen",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Codex Operator",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "bootstrap.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "key": ""
}
